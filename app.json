      "predictiveBackGestureEnabled": false,
      "package": "com.tekopakka.cofferer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "92ef9d06-ffab-4b9f-8f16-4dde32daa651"
